# Firebase Web config (Project Settings > General > Your apps > SDK setup and configuration)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=elderease-pranvxag.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=elderease-pranvxag
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=elderease-pranvxag.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=994743956796
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google OAuth client IDs
# Keep WEB set (used for Firebase credential exchange)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Optional per-platform IDs (recommended for native builds)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# Optional for Expo Go auth flow
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=
